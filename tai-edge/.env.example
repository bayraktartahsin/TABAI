# Server
PORT=3001
DB_PATH=./data/tai.db

# Core API keys
OPENROUTER_API_KEY=sk-or-v1-xxxxx
FAL_AI_API_KEY=xxxxx
TAI_SESSION_SECRET=your-secret-key-here
TAI_ENCRYPTION_KEY=your-encryption-key-here

# Email (Resend)
RESEND_API_KEY=re_xxxxx
TAI_EMAIL_FROM=TABAI <tabai@gravitilabs.com>
TAI_EMAIL_REPLY_TO=tabai@gravitilabs.com

# Auth settings
TAI_AUTH_EXPOSE_TOKENS=false
TAI_PUBLIC_ORIGIN=https://ai.gravitilabs.com

# Google OAuth
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# Apple App Store (IAP verification)
APPLE_APP_STORE_BUNDLE_ID=
APPLE_APP_STORE_ISSUER_ID=
APPLE_APP_STORE_KEY_ID=
APPLE_APP_STORE_PRIVATE_KEY=

# Store / Monetization
TAI_STORE_PRODUCT_PLAN_MAP=

# Bootstrap (seed admin user on first run)
TAI_BOOTSTRAP_ENABLE=false
TAI_BOOTSTRAP_ADMIN_EMAIL=
TAI_BOOTSTRAP_ADMIN_PASSWORD=
TAI_BOOTSTRAP_ADMIN_USERNAME=admin
TAI_BOOTSTRAP_ADMIN_DISPLAY_NAME=TAI Admin
